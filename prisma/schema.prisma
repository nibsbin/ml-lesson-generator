// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model ContentBlock {
  id               String   @id @default(uuid())
  domain           String
  type             String
  payload          String
  difficulty_level Int
  createdAt        DateTime @default(now())
}

model Lesson {
  id        String   @id @default(uuid())
  blocks    String
  createdAt DateTime @default(now())
}
